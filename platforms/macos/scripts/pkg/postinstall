#!/bin/sh
# Best-effort post-install. The pkg payload already placed Funput.app at
# /Library/Input Methods/Funput.app (system-wide), which is a valid input-method
# search location — so the install is correct even if nothing below runs. We only
# nudge LaunchServices to register it and launch it in the logged-in user's
# session so Funput appears without a logout.
#
# CRITICAL: never let this fail the install. A non-zero exit makes Installer abort
# the whole package (PKInstallErrorDomain Code=112), even though the files are
# already in place. So: no `set -e`, every step guarded, always exit 0.

APP="/Library/Input Methods/Funput.app"
LSR="/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister"

# Register the bundle system-wide (LaunchServices keys input sources by bundle id).
"$LSR" -f "$APP" 2>/dev/null || true

# Best-effort: refresh + launch inside the console user's GUI session so it shows
# up immediately. Skipped cleanly when there is no GUI user (SSH / login window).
CONSOLE_UID="$(stat -f%u /dev/console 2>/dev/null || echo 0)"
CONSOLE_USER="$(stat -f%Su /dev/console 2>/dev/null || echo root)"
if [ "$CONSOLE_UID" != "0" ] && [ "$CONSOLE_USER" != "root" ] && [ -n "$CONSOLE_USER" ]; then
    launchctl asuser "$CONSOLE_UID" sudo -u "$CONSOLE_USER" "$LSR" -f "$APP" 2>/dev/null || true
    launchctl asuser "$CONSOLE_UID" sudo -u "$CONSOLE_USER" /usr/bin/open "$APP" 2>/dev/null || true
fi

exit 0
